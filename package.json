{
  "name": "weblogue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "calib": "tsx tools/calib/cli.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:calib": "tsc --noEmit -p tools/calib",
    "check:calib": "npm run typecheck:calib",
    "check": "npm run typecheck && npm run typecheck:calib && npm test"
  },
  "devDependencies": {
    "@julusian/midi": "^3.6.1",
    "@types/node": "^26.1.0",
    "happy-dom": "^20.10.6",
    "tsx": "^4.23.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
}
